<!--    Constructor Dependency Injection -->
    <bean class="com.cts.entity.Address" id="address1">
        <constructor-arg name="city" value="Pune"/>
        <constructor-arg name="state" value="Maharashtra"/>
    </bean>
    <bean class="com.cts.entity.Student" id="student2">
        <constructor-arg name="name" value="Satyarthi"/>
        <constructor-arg name="age" value="21"/>
        <constructor-arg name="rollNumber" value="102"/>
        <constructor-arg name="address" ref="address1"/>
    </bean>
